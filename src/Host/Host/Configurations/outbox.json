{
  "OutboxOptions": {
    "IsProcessor": true,
    "PollIntervalMs": 250,
    "BatchSize": 100,
    "MaxRetryCount": 5,
    "BaseBackoffSeconds": 5,
    "MaxBackoffSeconds": 600,
    "PublishTimeoutMs": 5000,
    "ClaimLeaseSeconds": 120,
    "LagThresholdMinutes": 5,
    "MetricsCronSchedule": "*/5 * * * *",
    "Cleanup": {
      "Enabled": true,
      "RetentionDays": 7,
      "BatchSize": 1000,
      "CronSchedule": "0 3 * * *"
    }
  }
}