{
  "ObservabilityOptions": {
    "AppName": "modular-monolith",
    "AppVersion": "1.0.0",
    "MinimumLevel": "Debug",
    "MinimumLevelOverrides": {
      "Microsoft": "Warning",
      "Hangfire": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "ZiggyCreatures.Caching.Fusion": "Warning"
    },
    "WriteToConsole": true,
    "WriteToFile": true,
    "ResponseTimeThresholdInMs": 1000,
    "EnableMetrics": true,
    "EnableTracing": true,
    "OtlpEndpoint": "http://localhost:18889",
    "OtlpProtocol": "Grpc"
  }
}
