{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["nuget", "github-actions", "dockerfile"],
  "timezone": "Europe/Istanbul",
  "schedule": ["every weekend"],
  "packageRules": [
    {
      "groupName": "Microsoft packages",
      "automerge": false,
      "matchPackageNames": [
        "Microsoft.{/,}**"
      ]
    },
    {
      "groupName": "OpenTelemetry packages",
      "automerge": false,
      "matchPackageNames": [
        "OpenTelemetry.{/,}**"
      ]
    },
    {
      "groupName": "MassTransit packages",
      "automerge": false,
      "allowedVersions": "<9.0.0",
      "description": "Pin to free v8 (Apache 2.0). v9+ requires a commercial license.",
      "matchPackageNames": [
        "MassTransit{/,}**"
      ]
    },
    {
      "groupName": "Test packages",
      "automerge": false,
      "matchPackageNames": [
        "xunit{/,}**",
        "NSubstitute{/,}**",
        "Bogus{/,}**",
        "Testcontainers{/,}**",
        "Respawn{/,}**"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": false
    },
    {
      "groupName": "Docker images",
      "matchManagers": ["dockerfile"],
      "automerge": false
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
